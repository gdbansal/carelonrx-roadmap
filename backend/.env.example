# MongoDB Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carelonrx-roadmap?retryWrites=true&w=majority

# Frontend URL (for CORS) - comma-separated for multiple origins
FRONTEND_URL=https://carelonrx-roadmap.onrender.com

# Server Port
PORT=5000

# JWT Secret - generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# Encryption key for email-at-rest - generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=replace_with_32_byte_hex_string

# Admin default password (only used when DB is empty on first run)
ADMIN_DEFAULT_PASSWORD=ChangeMe@FirstLogin1

# JIRA Integration - Primary Instance (CarelonRx)
# Base URL of your self-hosted Jira DC instance (no trailing slash)
JIRA_BASE_URL=https://jira.yourcompany.com
# Personal Access Token — generate at: Jira Profile → Personal Access Tokens
JIRA_API_TOKEN=your_jira_pat_token

# JIRA Integration - Secondary Instance (Elevance Health)
JIRA2_BASE_URL=https://jira2.yourcompany.com
JIRA2_API_TOKEN=your_jira2_pat_token

# Confluence Base URL (uses same JIRA_API_TOKEN for auth)
CONFLUENCE_BASE_URL=https://confluence.carelonrx.com

# Story Mapping Mode: rule-based (default) | huggingface (future)
STORY_MAPPING_MODE=rule-based
