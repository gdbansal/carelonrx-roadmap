# MongoDB Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carelonrx-roadmap?retryWrites=true&w=majority

# Frontend URL (for CORS)
FRONTEND_URL=https://carelonrx-roadmap1.onrender.com

# Server Port
PORT=5000

# JIRA Integration
# Base URL of your Atlassian instance (no trailing slash)
JIRA_BASE_URL=https://yourcompany.atlassian.net
# Atlassian account email
JIRA_EMAIL=your-email@company.com
# Atlassian API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_atlassian_api_token
